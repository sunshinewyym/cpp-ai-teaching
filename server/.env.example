DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# MiMo（将 AI_PROVIDER 改为 mimo 后启用）
MIMO_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5
PORT=3000

# 可选：使用其他 OpenAI 兼容模型服务时设置以下变量。
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
# AI_API_KEY 留空时继续读取 DEEPSEEK_API_KEY。
AI_API_KEY=

# Algorithm Coach
COACH_TIMEOUT_MS=90000
COACH_MODEL_RETRIES=1
COACH_MAX_ROUNDS=16

# JWT Secret (用于登录认证，部署时请修改为随机字符串)
JWT_SECRET=your-random-secret-key-here

# 数据存储目录（默认 ./data）
DATA_DIR=./data
